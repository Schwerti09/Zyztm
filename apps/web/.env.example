# =============================================================================
# FORTNITE NEXUS - DIGITAL PRODUCTS ENVIRONMENT VARIABLES
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (for local development)
# 2. Replace placeholder values with your actual keys
# 3. For production, add these to Netlify Environment Variables
#    (Site Settings > Environment Variables)
# 4. NEVER commit .env files with real keys to git
#
# =============================================================================

# =============================================================================
# NEON DATABASE CONFIGURATION
# =============================================================================
# Get connection string from: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require

DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# STRIPE CONFIGURATION  
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
#
# Test mode keys start with: pk_test_... and sk_test_...
# Live mode keys start with: pk_live_... and sk_live_...
# 
# IMPORTANT: Use test keys for development!

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# RESEND EMAIL CONFIGURATION
# =============================================================================
# Get API key from: https://resend.com/api-keys
# Verify domain first: https://resend.com/domains

RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=orders@fortnitenexus.space
FROM_NAME=Fortnite Nexus

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Used for redirects and links in emails

URL=https://fortnitenexus.space
NODE_ENV=development

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================
# Uncomment if you want to add monitoring

# SENTRY_DSN=your-sentry-dsn-here
# POSTHOG_API_KEY=your-posthog-key-here

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
#
# [ ] 1. Neon Database setup
#     → https://console.neon.tech
#     → Create project (or use existing)
#     → Copy connection string to DATABASE_URL
#     → Run SQL migrations (sql/ folder)
#
# [ ] 2. Create Stripe account
#     → https://dashboard.stripe.com
#     → Enable "Tax" for EU VAT calculation
#     → Create products in Stripe
#     → Copy Price IDs to products table
#     → Add keys to .env
#
# [ ] 3. Setup Resend
#     → https://resend.com
#     → Verify domain (fortnitenexus.space)
#     → Create API key
#     → Add to .env
#
# [ ] 4. Configure Stripe Webhook (for production)
#     → Stripe Dashboard > Developers > Webhooks
#     → Add endpoint: https://fortnitenexus.space/.netlify/functions/stripe-webhook
#     → Select events:
#       - checkout.session.completed
#       - checkout.session.async_payment_succeeded
#       - invoice.paid
#       - invoice.payment_failed
#       - customer.subscription.deleted
#       - charge.refunded
#     → Copy webhook signing secret to .env
#
# [ ] 5. Upload product files
#     → Host product ZIPs on external storage (R2, S3, etc.)
#     → Add file URLs to products.file_url column in DB
#
# [ ] 6. Deploy to Netlify
#     → Add all env vars to Netlify Site Settings
#     → Deploy site
#     → Test checkout flow end-to-end
#
# =============================================================================
