# Discord Bot Credentials
# Erstelle eine App unter https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-client-id

# Optional: Guild-ID für schnelles Command-Testing (sofortige Registrierung)
DISCORD_GUILD_ID=your-guild-id

# Channel-ID für tägliche Shop-Alerts (Rechtsklick auf Channel → ID kopieren)
SHOP_ALERT_CHANNEL_ID=your-channel-id
